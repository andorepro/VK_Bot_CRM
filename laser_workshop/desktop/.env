# Основные настройки
SECRET_KEY=laser_workshop_desktop_secret_key_2026_change_this
DEBUG_MODE=False
HOST=0.0.0.0
PORT=5000

# HTTPS/SSL настройки
USE_HTTPS=True
CERT_FILE=certs/server.crt
KEY_FILE=certs/server.key

# База данных
DB_NAME=workshop.db
DB_BACKUP_DIR=backups

# Оптимизация производительности (Desktop версия)
MAX_CONNECTIONS=10
THREAD_POOL_SIZE=5
CACHE_SIZE_MB=64

# Кэширование
CACHE_TTL_SECONDS=300
MAX_USER_STATES=1000

# VK API
VK_TOKEN=YOUR_VK_TOKEN_HERE
VK_GROUP_ID=YOUR_GROUP_ID

# Платежные системы
YOOKASSA_SECRET=YOUR_YOOKASSA_SECRET
CDEK_API_KEY=YOUR_CDEK_API_KEY

# AI Прогнозирование (включено для Desktop)
AI_PROGNOSIS_ENABLED=True

# Скидки (пороги и проценты)
DISCOUNT_TIER_1_QTY=10
DISCOUNT_TIER_1_PERCENT=5
DISCOUNT_TIER_2_QTY=20
DISCOUNT_TIER_2_PERCENT=10
DISCOUNT_TIER_3_QTY=50
DISCOUNT_TIER_3_PERCENT=15
DISCOUNT_TIER_4_QTY=100
DISCOUNT_TIER_4_PERCENT=20

# Администратор по умолчанию
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# JWT Токен
JWT_EXPIRATION_DAYS=7
