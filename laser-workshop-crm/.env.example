# VK API Configuration
VK_TOKEN=your_vk_service_token_here
VK_GROUP_ID=your_group_id_negative_number
ADMIN_IDS=12345678,87654321

# Database Configuration
DB_PATH=workshop.db
DATABASE_URL=laser_workshop.db

# Security & JWT
SECRET_KEY=super_secret_random_string_change_in_production
JWT_EXPIRATION_HOURS=168
DEFAULT_ADMIN_PASSWORD=admin123

# Server Configuration
FLASK_ENV=production
HOST=0.0.0.0
PORT=5000
DEBUG_MODE=False
USE_HTTPS=false
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# Integrations (Optional)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
CDEK_API_KEY=your_cdek_key
MY_SKLAD_API_KEY=your_mysklad_key
1C_API_URL=http://localhost:8080/api

# Notifications
ADMIN_TELEGRAM_ID=your_telegram_id_for_alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token