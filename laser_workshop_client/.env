# Основные настройки клиента
HOST=0.0.0.0
PORT=5001

# HTTPS/SSL настройки
USE_HTTPS=True
CERT_FILE=certs/server.crt
KEY_FILE=certs/server.key

# Настройки подключения к серверу
SERVER_HOST=localhost
SERVER_PORT=5000
SERVER_PROTOCOL=https
VERIFY_SERVER_SSL=False

# Офлайн режим
OFFLINE_MODE=False
AUTO_SYNC=True

# Кэширование
CACHE_TTL_SECONDS=60
